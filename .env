# =============== API KEYS ===============
# At least one LLM API key is required

# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
GOOGLE_API_KEY="AIzaSyAIBHplJX_uTz2odP8Z_9GZ960lHd00pAI"

# =============== LLM CONFIGURATION ===============
# Available models: gpt-4-turbo, claude-opus, gemini-pro
LLM_MODEL=gemini-pro
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# =============== OBSERVABILITY ===============
# Optional: Enable tracing with LangSmith or Langfuse
USE_LANGSMITH=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-ai-research

USE_LANGFUSE=false
LANGFUSE_API_KEY=
LANGFUSE_SECRET_KEY=

# =============== APPLICATION SETTINGS ===============
DEBUG=false
LOG_LEVEL=INFO
MAX_SEARCH_RESULTS=5
MAX_URL_EXTRACTIONS=3
REQUEST_TIMEOUT=10
ENABLE_MULTI_AGENT=true
AGENT_VERBOSE=true
